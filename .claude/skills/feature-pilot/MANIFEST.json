{
  "schema_version": 2,
  "skill_id": "feature-pilot",
  "tier": 1,
  "tier_description": "Orchestrator - AI 주도 기능 개발의 통합 오케스트레이터",
  "enforced_protocol": {
    "version": "2.0",
    "preflight_required": true,
    "postflight_required": true,
    "model_routing_required": true,
    "evidence_caching_enabled": true
  },
  "model_routing": {
    "default_model": "sonnet",
    "task_specific": {
      "work_type_classification": "sonnet",
      "context_collection": "sonnet",
      "readiness_gate": "sonnet",
      "implementation": "sonnet",
      "architecture_decision": "opus"
    },
    "fallback_chain": [
      "sonnet",
      "opus"
    ]
  },
  "evidence_policy": {
    "npm_lint": {
      "ttl_minutes": 30,
      "invalidation": "src/**/*.{ts,tsx} changes"
    },
    "npm_test": {
      "ttl_minutes": 30,
      "invalidation": "tests/**/*.{ts,tsx}, src/**/*.{ts,tsx} changes"
    },
    "readiness_gate": {
      "ttl_minutes": 60,
      "invalidation": "SPEC-*.md, screens/*.md changes"
    },
    "security_scan": {
      "ttl_minutes": 60,
      "invalidation": ".env* changes"
    }
  },
  "preflight_checks": [
    {
      "id": "PF-000",
      "description": "Path Resolution 완료 (project-config.json 읽기)",
      "blocking": true
    },
    {
      "id": "PF-001",
      "description": "작업 유형 판별 완료",
      "blocking": true
    },
    {
      "id": "PF-002",
      "description": "CONTEXT.json 접근 가능 또는 신규 생성 가능",
      "blocking": true
    },
    {
      "id": "PF-003",
      "description": "CLAUDE.md 규칙 확인",
      "blocking": true
    },
    {
      "id": "PF-004",
      "description": "Feature Characteristics 판정 완료",
      "blocking": true
    },
    {
      "id": "PF-005",
      "description": "Evidence 캐시 확인",
      "blocking": false
    },
    {
      "id": "PF-006",
      "description": "하위 스킬 ESP 호환성 확인",
      "blocking": true
    },
    {
      "id": "PF-007",
      "description": "작업 ID 확정",
      "blocking": true
    },
    {
      "id": "PF-008",
      "description": "worktree 생성 및 PLAN.md 초기화",
      "blocking": true
    },
    {
      "id": "PF-009",
      "description": "Target Scope 확정 (brief2dev 본체 vs output/<slug> 생성 프로젝트)",
      "blocking": true
    },
    {
      "id": "PF-010",
      "description": "Domain Placement 판정 완료 (domain-map.json + index.md 조회)",
      "blocking": true
    }
  ],
  "postflight_checks": [
    {
      "id": "POF-001",
      "description": "파이프라인 완료 또는 명시적 중단",
      "blocking": true
    },
    {
      "id": "POF-002",
      "description": "CONTEXT.json 최종 상태 업데이트",
      "blocking": true
    },
    {
      "id": "POF-003",
      "description": "QA 검증 통과 (pre-quality-gate)",
      "blocking": true
    },
    {
      "id": "POF-004",
      "description": "하위 스킬 Post-flight 모두 완료",
      "blocking": true
    },
    {
      "id": "POF-005",
      "description": "Evidence 캐시 완료",
      "blocking": false
    },
    {
      "id": "POF-006",
      "description": "DoD 검증 완료 (completion_contract verdict = passed)",
      "blocking": true
    },
    {
      "id": "POF-007",
      "description": "worktree PLAN.md 및 CONTEXT.json cleanup 완료",
      "blocking": true
    }
  ],
  "public_api": {
    "direct_invocable": true,
    "trigger_keywords": [
      "신규 기능",
      "버그 수정",
      "기능 수정",
      "개발 요청",
      "구현해줘",
      "feature-pilot"
    ],
    "args_pattern": "<자연어 요청> [--quick] [--docs-only]"
  },
  "dependencies": {
    "required": [],
    "optional": []
  },
  "called_by": [
    "decide",
    "mvp-launcher",
    "discovery-decision-backbone"
  ],
  "calls": [
    "feature-architect",
    "feature-spec-generator",
    "feature-spec-updater",
    "ui-approval-gate",
    "feature-implementer",
    "engineering-plan-writer",
    "feature-wiring",
    "feature-status-sync",
    "bug-fix",
    "pre-quality-gate",
    "priority-analyzer",
    "research-pilot",
    "discover",
    "infra-selector",
    "architecture-selector",
    "domain-modeler",
    "system-designer",
    "contract-codegen",
    "contract-tester",
    "prioritize",
    "design-pilot",
    "final-review",
    "market-intelligence-scanner",
    "research-gap-analyzer",
    "story-decomposer",
    "verification-loop",
    "de-sloppify"
  ],
  "work_types": {
    "NEW_FEATURE": {
      "triggers": [
        "신규 기능",
        "추가",
        "SPEC 미존재"
      ],
      "pipeline": [
        "research-pilot (conditional)",
        "feature-architect",
        "feature-spec-generator",
        "story-decomposer (optional)",
        "ui-approval-gate",
        "readiness-gate (built-in)",
        "implementation",
        "feature-wiring",
        "pre-quality-gate",
        "feature-status-sync",
        "priority-analyzer (optional)",
        "pre-quality-gate (final)"
      ]
    },
    "MODIFY_FEATURE": {
      "triggers": [
        "수정",
        "변경",
        "기존 SPEC 존재"
      ],
      "pipeline": [
        "feature-spec-updater",
        "ui-approval-gate",
        "readiness-gate (built-in)",
        "implementation",
        "feature-wiring (conditional)",
        "feature-status-sync",
        "priority-analyzer (optional)",
        "pre-quality-gate (optional)"
      ]
    },
    "BUG_FIX": {
      "triggers": [
        "버그",
        "오류",
        "수정"
      ],
      "pipeline": [
        "bug-fix",
        "pre-quality-gate (optional)"
      ]
    },
    "DOCS_ONLY": {
      "triggers": [
        "문서만",
        "SPEC만"
      ],
      "pipeline": [
        "specified skill only"
      ]
    }
  },
  "execution_model": {
    "type": "orchestrator",
    "phases": [
      {
        "id": 0,
        "name": "요청 접수 및 분류",
        "description": "작업 타입 자동 판별, Tier 판정, CLAUDE.md 체크"
      },
      {
        "id": 1,
        "name": "계획 제시",
        "description": "파이프라인 계획을 사용자에게 제시"
      },
      {
        "id": 2,
        "name": "파이프라인 실행",
        "description": "작업 타입별 파이프라인의 순차 실행"
      },
      {
        "id": 3,
        "name": "진행 상황 추적",
        "description": "각 단계 완료 시 상태 업데이트 및 보고"
      }
    ],
    "built_in_features": [
      "Readiness Gate (5 Phase 검증)",
      "State Machine (CONTEXT.json)",
      "7문항 상한 규칙",
      "자율성 제어"
    ]
  },
  "inputs": [
    {
      "type": "user_request",
      "description": "자연어 개발 요청"
    }
  ],
  "outputs": [
    {
      "type": "implementation",
      "format": "project-config.language",
      "description": "완전한 기능 구현"
    },
    {
      "type": "context",
      "format": "json",
      "description": "CONTEXT.json 상태 업데이트"
    }
  ],
  "references": [
    {
      "file": "references/feature-pilot-protocol-details.md",
      "description": "기존 전체 feature-pilot 오케스트레이션 프로토콜 아카이브. 긴 파이프라인 예시, 사용자 인터랙션, 상세 DO/DON'T가 필요할 때만 참조"
    },
    {
      "file": "references/context-management-protocol.md",
      "description": "CONTEXT.json 상태 머신, 라이프사이클, DoD 검증"
    },
    {
      "file": "references/readiness-gate-protocol.md",
      "description": "내장 Readiness Gate의 5-Phase 검증 구조, 출력 형식, 판정 기준"
    },
    {
      "file": "references/efficiency-skills-protocol.md",
      "description": "pre-quality-gate 운영 상세"
    },
    {
      "file": "references/autonomy-control-rules.md",
      "description": "7문 상한, 자율성 레벨, 자동 정지 조건"
    }
  ],
  "ssot_files": [
    "Makefile"
  ]
}
