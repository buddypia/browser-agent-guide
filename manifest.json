{
  "manifest_version": 3,
  "name": "Browser Agent Guide",
  "version": "0.1.0",
  "description": "Guardrails for browser-operating AIs: a Chrome side-panel agent that drives any page through a closed, deterministic verb registry using Structured Outputs.",
  "minimum_chrome_version": "135",
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Browser Agent Guide を開く",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "options_page": "options/options.html",
  "permissions": [
    "storage",
    "sidePanel",
    "scripting",
    "tabs",
    "userScripts",
    "offscreen",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
